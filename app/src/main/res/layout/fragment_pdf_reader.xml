<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top Info Bar -->
    <LinearLayout
        android:id="@+id/ll_reader_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_page_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Page 1 / 1"
            android:textColor="@color/text_primary_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_night_mode"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/module_reader"
            android:src="@drawable/ic_night_mode" />

    </LinearLayout>

    <!-- Main Page Image Container -->
    <ImageView
        android:id="@+id/iv_pdf_page_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/module_reader"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_reader_bar" />

    <!-- Bottom Page Slider Controls -->
    <LinearLayout
        android:id="@+id/ll_bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_page"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="1"
            android:valueTo="1"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
