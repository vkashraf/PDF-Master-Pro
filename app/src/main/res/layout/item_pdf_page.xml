<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="120dp"
    android:layout_height="160dp"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/card_stroke_dark"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/card_bg_dark">

        <ImageView
            android:id="@+id/iv_page_image"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:contentDescription="@string/module_reader"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toTopOf="@id/tv_page_number"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/view_selection_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66FF3B30"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_page_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_dark"
            android:gravity="center"
            android:padding="4dp"
            android:textColor="@color/text_primary_dark"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
